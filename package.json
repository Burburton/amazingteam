{
  "name": "ai-team-template",
  "version": "1.0.0",
  "description": "AI-powered autonomous development team template - Reusable development foundation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-team": "./cli/ai-team.cjs"
  },
  "files": [
    ".ai-team/",
    "cli/",
    "ai-team.config.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "validate": "node scripts/validate-foundation.cjs"
  },
  "keywords": [
    "ai",
    "automation",
    "development",
    "template",
    "opencode",
    "github-actions",
    "autonomous",
    "dev-tools"
  ],
  "author": "AI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ai-team-template.git"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}