# AmazingTeam Foundation - .gitignore additions
# Add these lines to your project's .gitignore

# AmazingTeam cache (downloaded foundation)
.amazingteam-cache/

# Local foundation (downloaded by `amazingteam local`)
.amazingteam-local/

# OpenCode config (auto-generated, can be regenerated)
# opencode.jsonc

# Task memory (optional - uncomment if you don't want to track tasks)
# tasks/issue-*/

# Memory files (optional - uncomment if you don't want to track memory)
# .ai-team/memory/**/*.md