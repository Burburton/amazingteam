{
  "$schema": "https://opencode.ai/schema.json",
  "version": "{{AI_TEAM_VERSION}}",
  "project": {
    "name": "{{PROJECT_NAME}}",
    "description": "{{PROJECT_DESCRIPTION}}",
    "language": "{{LANGUAGE}}",
    "framework": "{{FRAMEWORK}}"
  },
  "agents": {
    "planner": {
      "description": "Decomposes tasks and coordinates workflow progression",
      "model": "default",
      "skills": ["task-breakdown-and-dispatch"],
      "commands": [],
      "memory": {
        "read": ["docs/", "AGENTS.md", ".amazing-team/memory/planner/", ".amazing-team/memory/architect/", ".amazing-team/memory/triage/", ".amazing-team/memory/failures/", "tasks/"],
        "write": [".amazing-team/memory/planner/", "tasks/{task_id}/task.yaml"]
      }
    },
    "architect": {
      "description": "Analyzes requirements and designs solutions",
      "model": "default",
      "skills": ["repo-architecture-reader"],
      "commands": ["/design"],
      "memory": {
        "read": ["docs/", "AGENTS.md", ".amazing-team/memory/planner/", ".amazing-team/memory/architect/", ".amazing-team/memory/developer/", ".amazing-team/memory/failures/", "tasks/"],
        "write": [".amazing-team/memory/architect/", "tasks/{task_id}/analysis.md", "tasks/{task_id}/design.md"]
      }
    },
    "developer": {
      "description": "Implements features and fixes bugs",
      "model": "default",
      "skills": ["test-first-feature-dev", "bugfix-playbook"],
      "commands": ["/implement"],
      "memory": {
        "read": ["docs/", "AGENTS.md", ".amazing-team/memory/planner/", ".amazing-team/memory/architect/", ".amazing-team/memory/developer/", ".amazing-team/memory/failures/", "tasks/{task_id}/"],
        "write": [".amazing-team/memory/developer/", "tasks/{task_id}/implementation.md", "src/", "tests/"]
      }
    },
    "qa": {
      "description": "Validates implementations and ensures quality",
      "model": "default",
      "skills": ["test-first-feature-dev", "regression-checklist"],
      "commands": ["/test"],
      "memory": {
        "read": ["docs/", "AGENTS.md", ".amazing-team/memory/planner/", ".amazing-team/memory/architect/", ".amazing-team/memory/qa/", ".amazing-team/memory/failures/", "tasks/{task_id}/"],
        "write": [".amazing-team/memory/qa/", "tasks/{task_id}/validation.md", "tests/"]
      }
    },
    "reviewer": {
      "description": "Reviews code for quality and correctness",
      "model": "default",
      "skills": ["safe-refactor-checklist", "regression-checklist", "release-readiness-check"],
      "commands": ["/review", "/release-check"],
      "memory": {
        "read": ["docs/", "AGENTS.md", ".amazing-team/memory/", ".amazing-team/memory/failures/", "tasks/{task_id}/"],
        "write": [".amazing-team/memory/reviewer/", "tasks/{task_id}/review.md", "tasks/{task_id}/release.md"]
      }
    },
    "triage": {
      "description": "Classifies issues and performs first-pass debug analysis",
      "model": "default",
      "skills": ["issue-triage", "bugfix-playbook"],
      "commands": ["/triage"],
      "memory": {
        "read": ["docs/", "AGENTS.md", ".amazing-team/memory/triage/", ".amazing-team/memory/failures/", "tasks/{task_id}/"],
        "write": [".amazing-team/memory/triage/", "tasks/{task_id}/"]
      }
    },
    "ci-analyst": {
      "description": "Investigates CI failures and documents patterns",
      "model": "default",
      "skills": ["ci-failure-analysis", "bugfix-playbook"],
      "commands": ["/ci-analyze"],
      "memory": {
        "read": ["docs/", "AGENTS.md", ".amazing-team/memory/ci-analyst/", ".amazing-team/memory/failures/", "tasks/{task_id}/", "docs/runbooks/ci/"],
        "write": [".amazing-team/memory/ci-analyst/", ".amazing-team/memory/failures/", "tasks/{task_id}/"]
      }
    }
  },
  "skills": {
    "repo-architecture-reader": {
      "path": ".amazing-team/skills/repo-architecture-reader/skill.md"
    },
    "bugfix-playbook": {
      "path": ".amazing-team/skills/bugfix-playbook/skill.md"
    },
    "test-first-feature-dev": {
      "path": ".amazing-team/skills/test-first-feature-dev/skill.md"
    },
    "safe-refactor-checklist": {
      "path": ".amazing-team/skills/safe-refactor-checklist/skill.md"
    },
    "task-breakdown-and-dispatch": {
      "path": ".amazing-team/skills/task-breakdown-and-dispatch/skill.md"
    },
    "issue-triage": {
      "path": ".amazing-team/skills/issue-triage/skill.md"
    },
    "ci-failure-analysis": {
      "path": ".amazing-team/skills/ci-failure-analysis/skill.md"
    },
    "regression-checklist": {
      "path": ".amazing-team/skills/regression-checklist/skill.md"
    },
    "release-readiness-check": {
      "path": ".amazing-team/skills/release-readiness-check/skill.md"
    }
  },
  "commands": {
    "/triage": {
      "path": ".amazing-team/commands/triage.md",
      "agent": "triage"
    },
    "/design": {
      "path": ".amazing-team/commands/design.md",
      "agent": "architect"
    },
    "/implement": {
      "path": ".amazing-team/commands/implement.md",
      "agent": "developer"
    },
    "/test": {
      "path": ".amazing-team/commands/test.md",
      "agent": "qa"
    },
    "/review": {
      "path": ".amazing-team/commands/review.md",
      "agent": "reviewer"
    },
    "/ci-analyze": {
      "path": ".amazing-team/commands/ci-analyze.md",
      "agent": "ci-analyst"
    },
    "/release-check": {
      "path": ".amazing-team/commands/release-check.md",
      "agent": "reviewer"
    }
  },
  "workflows": {
    "feature": ["planner", "architect", "developer", "qa", "reviewer"],
    "bugfix": ["triage", "architect", "developer", "qa", "reviewer"],
    "refactor": ["architect", "developer", "reviewer"],
    "ci-failure": ["ci-analyst", "developer", "qa"],
    "release": ["reviewer"]
  },
  "memory": {
    "global": {
      "locations": ["docs/", "AGENTS.md"],
      "writeRequiresApproval": true
    },
    "role": {
      "base_path": ".amazing-team/memory",
      "roles": {
        "planner": {
          "files": ["decomposition_notes.md", "flow_rules.md"]
        },
        "architect": {
          "files": ["architecture_notes.md", "module_map.md", "design_rationale.md"]
        },
        "developer": {
          "files": ["implementation_notes.md", "bug_investigation.md", "build_issues.md"]
        },
        "qa": {
          "files": ["test_strategy.md", "regression_cases.md", "validation_notes.md"]
        },
        "reviewer": {
          "files": ["review_notes.md", "quality_rules.md", "recurring_risks.md"]
        },
        "triage": {
          "files": ["classification_heuristics.md", "debug_notes.md"]
        },
        "ci-analyst": {
          "files": ["failure_patterns.md", "runbook_references.md"]
        }
      }
    },
    "failures": {
      "path": ".amazing-team/memory/failures",
      "files": ["failure_library.md"],
      "writableBy": ["ci-analyst"]
    },
    "task": {
      "base_path": "tasks",
      "naming": "issue-{issue_id}",
      "files": ["task.yaml", "analysis.md", "design.md", "implementation.md", "validation.md", "review.md", "release.md"],
      "autoCreate": true,
      "preserveAfterCompletion": true
    }
  },
  "rules": {
    "maxChangesPerCommit": 10,
    "requireTests": true,
    "requireReview": true,
    "autoMerge": false,
    "memoryIsolation": true,
    "protectedPaths": ["docs/architecture/", "docs/decisions/"],
    "humanApprovalRequired": ["architecture changes", "release operations", "breaking changes"]
  },
  "integrations": {
    "github": {
      "enabled": true,
      "autoLabel": true,
      "autoAssign": true
    },
    "ci": {
      "enabled": true,
      "requirePassing": true,
      "failureAnalysis": {
        "enabled": true,
        "agent": "ci-analyst"
      }
    }
  }
}