{
  "$schema": "https://opencode.ai/config.json",
  "model": "default",
  "small_model": "default",
  "default_agent": "build",
  "instructions": ["AGENTS.md"],
  "autoupdate": true,
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "tools": {
    "write": true,
    "edit": true,
    "bash": true
  }
}